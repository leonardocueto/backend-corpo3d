ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dashboard
# generar con: python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
SESSION_DAYS=7
# JSON array. En prod cross-site: ["https://app.tudominio.com"]
CORS_ORIGINS=["http://localhost:3000"]

