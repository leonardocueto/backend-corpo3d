ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dashboard
# generar con: python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
SESSION_DAYS=7
# JSON array. En prod cross-site: ["https://app.tudominio.com"]
CORS_ORIGINS=["http://localhost:3000"]

# ---- Recuperacion de contraseña (forgot/reset) ----
# Base del link que va en el mail: {FRONTEND_URL}/reset-password?token=xxx
FRONTEND_URL=http://localhost:3000
RESET_TOKEN_MINUTES=10
# Resend: si RESEND_API_KEY esta vacio, en dev se LOGUEA el link (no envia mail).
RESEND_API_KEY=
EMAIL_FROM=CorpoLab 3D <onboarding@resend.dev>

# ---- OTP de login (2do factor por email) ----
# Codigo de 6 digitos que se manda tras validar la password. Sin RESEND_API_KEY,
# en dev se LOGUEA el codigo (no envia mail).
# OTP_ENABLED: switch maestro. false (default) = login directo, SIN OTP (como antes);
# true = exige el codigo. Prender SOLO cuando el envio de emails ande para todos los
# usuarios (dominio verificado en Resend); si no, los demas quedarian sin poder entrar.
OTP_ENABLED=false
OTP_MINUTES=5
OTP_MAX_ATTEMPTS=5

# ---- Login con Google (OAuth 2.0 / OIDC) ----
# Client ID (PUBLICO) de Google Cloud Console -> APIs & Services -> Credentials ->
# OAuth client ID (Web application). Agregar http://localhost:3000 a "Authorized
# JavaScript origins". NO hay client secret en este flujo (ID token). Sin esto la
# app arranca igual, pero /auth/google responde 401 (login con Google deshabilitado).
# El front necesita el MISMO valor en NUXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=

# ---- Cloudflare R2 (disenos guardados; bucket PRIVADO, S3-compatible) ----
# Crear bucket + API token (Object Read & Write) en el dashboard de Cloudflare.
# Sin esto la app arranca igual, pero los endpoints /designs fallan al operar.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=corpolab-designs

# ---- Mercado Pago (Checkout Pro / pago unico) ----
# Credenciales de TU cuenta: developers.mercadopago.com -> Tus integraciones ->
# crear app -> Credenciales (usar las de TEST para probar, las de PROD al salir).
# El webhook necesita un BACKEND_URL PUBLICO (no llega a localhost): usar Render o
# un tunel (ngrok/cloudflared) apuntando a /payments/webhook. El MP_WEBHOOK_SECRET
# sale del panel de Webhooks de la app (clave secreta para validar la firma).
# Sin estas vars la app arranca igual, pero /payments/checkout responde 503.
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
BACKEND_URL=http://localhost:8000
PRICE_MENSUAL=10000
PRICE_ANUAL=100000
CURRENCY_ID=ARS

# ---- Produccion (Render + Neon + Vercel) ----
# NO van en el repo: se cargan como env vars en el dashboard de Render.
# (render.yaml ya declara ENVIRONMENT, COOKIE_SAMESITE, SESSION_SECRET, SESSION_DAYS)
#   DATABASE_URL=postgresql+psycopg://USER:PASS@HOST.neon.tech/DB?sslmode=require
#   CORS_ORIGINS=["https://<tu-front>.vercel.app"]
#   ENVIRONMENT=production
#   COOKIE_SAMESITE=none
#   FRONTEND_URL=https://<tu-front>.vercel.app
#   RESEND_API_KEY=re_xxxxxxxx   (dominio verificado en Resend)
#   EMAIL_FROM=CorpoLab 3D <no-reply@tudominio.com>
#   MP_ACCESS_TOKEN=APP_USR-...   (credencial de PROD de tu cuenta MP)
#   MP_WEBHOOK_SECRET=...         (clave del webhook de la app en MP)
#   BACKEND_URL=https://<tu-api>.onrender.com   (publica, para el notification_url)
